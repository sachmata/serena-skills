#!/bin/sh
# sr — thin wrapper around mcporter for Serena tools.
# Lazily registers Serena and starts the keep-alive daemon on first use.

SR_DIR="$(cd "$(dirname "$0")" && pwd)"
MCPORTER_DIR="$HOME/.mcporter"
MCPORTER_CFG="$MCPORTER_DIR/mcporter.json"
DAEMON_DIR="$MCPORTER_DIR/daemon"

# --- 1. Ensure Serena is registered in mcporter.json ---
if [ ! -f "$MCPORTER_CFG" ] || ! grep -q '"serena"' "$MCPORTER_CFG" 2>/dev/null; then
  mkdir -p "$MCPORTER_DIR"
  if [ -f "$MCPORTER_CFG" ]; then
    # Config exists but has no serena entry — merge it in via a tmp file
    # (jq may not be available, so use node which npx guarantees)
    node -e '
      const fs = require("fs");
      const p  = process.argv[1];
      const cfg = JSON.parse(fs.readFileSync(p, "utf8"));
      cfg.mcpServers = cfg.mcpServers || {};
      cfg.mcpServers.serena = {
        command: "uvx --from git+https://github.com/oraios/serena serena start-mcp-server",
        lifecycle: "keep-alive"
      };
      cfg.imports = cfg.imports || [];
      fs.writeFileSync(p, JSON.stringify(cfg, null, 2) + "\n");
    ' "$MCPORTER_CFG"
  else
    cat > "$MCPORTER_CFG" <<'EOF'
{
  "mcpServers": {
    "serena": {
      "command": "uvx --from git+https://github.com/oraios/serena serena start-mcp-server",
      "lifecycle": "keep-alive"
    }
  },
  "imports": []
}
EOF
  fi
  echo "sr: registered Serena in $MCPORTER_CFG" >&2
fi

# --- 2. Start the keep-alive daemon if not already running ---
if ! ls "$DAEMON_DIR"/*.sock >/dev/null 2>&1; then
  npx mcporter daemon start >&2
fi

# --- 3. Forward the call ---
exec npx mcporter call "serena.$1" "${@:2}"
